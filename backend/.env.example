# Oak Capital Backend — environment variables
# Copy this file to .env and fill in your values.
# The server runs without a database; auth/portfolio persistence requires Postgres.

# ─── Database (optional — server starts without it) ──────────────────────────
# Full connection string takes precedence over individual vars.
DB_URL=postgres://user:password@localhost:5432/synthbull

# Individual vars (used if DB_URL is not set):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
# DB_NAME=synthbull

# ─── Redis (event bus — pub/sub + durable streams) ───────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters in production.
JWT_SECRET=synthbull_change_me_in_production_32chars

# ─── SMTP (optional — required for forgot-password / delete-account emails) ──
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=smtp_password

# ─── WebSocket URL for simulation bots ────────────────────────────────────────
# WS_URL=ws://localhost:8080/ws
